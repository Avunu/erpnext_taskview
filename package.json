{
  "name": "erpnext-taskview",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "dev:dock": "BUNDLE=timerdock vite build --watch",
    "build": "vite build && BUNDLE=timerdock vite build && node update-assets.mjs",
    "build:taskview": "vite build",
    "build:timerdock": "BUNDLE=timerdock vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "oxlint erpnext_taskview/public/js",
    "lint:fix": "oxlint --fix erpnext_taskview/public/js",
    "format": "oxfmt --write erpnext_taskview/public/js",
    "format:check": "oxfmt --check erpnext_taskview/public/js",
    "upgrade-all": "npx npm-check-updates -u && yarn install"
  },
  "dependencies": {
    "@he-tree/vue": "^2.10.2",
    "@vueuse/core": "^14.2.1",
    "frappe-ui": "^0.1",
    "lucide-vue-next": "^1.0.0",
    "vue": "^3",
    "vue-demi": "^0.14.10",
    "vue3-side-panel": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vue-tsc": "^3.2.6"
  }
}
